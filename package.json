{
  "name": "zlhywlf.github.io",
  "version": "0.1.0",
  "description": "",
  "keywords": [],
  "author": "zlhywlf",
  "license": "MIT",
  "bin": {
    "vds": "bin/vds.js"
  },
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "scripts": {
    "dev": "run-p dev-client dev-server",
    "dev-client": "tsc -w --p src/client",
    "dev-server": "tsc -w --p src/server",
    "build": "tsc -p src/client && tsc -p src/server",
    "lint": "prettier --write --parser typescript \"src/**/*.ts\"",
    "test": "pnpm build && jest",
    "prepublishOnly": "tsc"
  },
  "jest": {
    "watchPathIgnorePatterns": [
      "<rootDir>/test/temp"
    ]
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.ts": [
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "@babel/parser": "^7.22.5",
    "@vue/compiler-sfc": "^3.0.0-beta.2",
    "chokidar": "^3.5.3",
    "magic-string": "^0.30.0",
    "resolve-cwd": "^3.0.0",
    "serve-handler": "^6.1.5",
    "vue": "^3.0.0-beta.3",
    "ws": "^7.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.3.0",
    "@types/serve-handler": "^6.1.1",
    "@types/ws": "^8.5.5",
    "execa": "^4.0.0",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "puppeteer": "^20.6.0",
    "typescript": "^5.1.3",
    "yorkie": "^2.0.0"
  }
}
